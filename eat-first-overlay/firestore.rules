rules_version = '2';
// Якщо змінюєш VITE_ADMIN_KEY — онови рядок нижче на той самий літерал (або винеси в custom claims).
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/{gameId} {
      allow read: if true;
      // Адмін-ключ — повне створення кімнати; або перший запис лише hands (гравець підняв руку до того, як ведучий натиснув OK).
      allow create: if request.resource.data.key == "123456"
        || (
          request.resource.data.keys().hasOnly(['hands'])
          && request.resource.data.hands is map
        )
        || (
          request.resource.data.keys().hasOnly(['playersReady'])
          && request.resource.data.playersReady is map
        );
      allow update: if request.resource.data.key == "123456"
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hands'])
          && request.resource.data.hands is map
        )
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playersReady'])
          && request.resource.data.playersReady is map
        );
      allow delete: if false;

      // Публічне голосування з персонального оверлею (без admin key)
      match /votes/{voterId} {
        allow read: if true;
        allow create, update: if request.resource.data.choice in ['for', 'against']
          && request.resource.data.targetPlayer is string
          && request.resource.data.targetPlayer.size() > 0
          && request.resource.data.round is int
          && request.resource.data.round >= 1
          && request.resource.data.round <= 8;
        // Видалення голосів при прибиранні гравця з кімнати (deleteVoteDoc) — request.resource немає.
        allow delete: if true;
      }
    }

    match /games/{gameId}/players/{playerId} {
      allow read: if true;
      allow create: if request.resource.data.key == "123456";

      // Оновлення ведучим (повний документ з key) або лише поля «зайняття» слота з лобі (joinToken / deviceId).
      function playerJoinDiffKeys() {
        return request.resource.data.diff(resource.data).affectedKeys();
      }
      function playerJoinPayloadOk() {
        let d = playerJoinDiffKeys();
        return request.resource.data.key == resource.data.key
          && resource.data.key == "123456"
          && (d.hasOnly(['joinToken', 'joinDeviceId', 'joinClaimedAt'])
            || d.hasOnly(['joinToken', 'joinDeviceId', 'joinClaimedAt', 'name']))
          && request.resource.data.joinToken is string
          && request.resource.data.joinToken.size() >= 32
          && request.resource.data.joinToken.size() <= 128
          && request.resource.data.joinDeviceId is string
          && request.resource.data.joinDeviceId.size() >= 8
          && request.resource.data.joinDeviceId.size() <= 128
          && request.resource.data.joinClaimedAt is timestamp
          && (!d.hasAny(['name'])
            || (request.resource.data.name is string && request.resource.data.name.size() <= 64))
          && (!resource.data.keys().hasAny(['joinToken'])
            || resource.data.joinToken == ''
            || resource.data.joinDeviceId == request.resource.data.joinDeviceId);
      }

      allow update: if request.resource.data.key == "123456"
        || playerJoinPayloadOk();

      // delete: request.resource немає; старі документи могли бути без поля key — тоді key == "123456" не спрацьовує.
      allow delete: if resource.data.key == "123456"
        || !resource.data.keys().hasAny(['key']);
    }
  }
}
