# Canonical: origin без слеша в кінці — у проді клієнт виставляє rel=canonical і og:url під повний path + query
# У репо вже є .env.production для https://eat-first-overlay.vercel.app
# VITE_PUBLIC_CANONICAL_ORIGIN=https://eat-first-overlay.vercel.app

# Plausible: домен сайту в акаунті Plausible (без https://)
# VITE_PLAUSIBLE_DOMAIN=eat-first-overlay.vercel.app

# Google Analytics 4 — лише якщо потрібно (Measurement ID G-…)
# VITE_GA_MEASUREMENT_ID=

# Firestore у dev: за замовчуванням кеш лише в RAM (стабільніше з Vite HMR). Увімкнути IndexedDB як у проді:
# VITE_FIRESTORE_DEV_PERSIST=true

# Cloud Functions (голосування + хост: очистка голосів, фаза) — регіон деплою, напр. europe-west1
# Увімкніть Anonymous Auth у Firebase Console. Секрет пароля ведучого:
#   firebase functions:secrets:set HOST_PROMOTE_PASSWORD
# Поки кімната ще пишеться з клієнта по key, збіги HOST_PROMOTE_PASSWORD з VITE_ADMIN_KEY.
# Без змінної — застосунок лишається на легасі-записах у Firestore для голосів (тільки для локалки без Functions).
# VITE_FUNCTIONS_REGION=europe-west1

# --- LiveKit (голос/відео на /overlay) ---
# Не залишай у .env / .env.local рядок VITE_LIVEKIT_URL= без значення (порожній рядок)
# — у збірці він може перебити змінні з Vercel / наступні рядки, і overlay лишиться «не налаштовано».
# Без коректного VITE_LIVEKIT_URL клієнт покаже «не налаштовано», кімната не стартує.
# Ключі беруться в https://cloud.livekit.io → Project → Settings → API Keys / WebSocket URL.
#
# Скопіюй блок у .env або .env.local (у цій самій папці, що package.json), підстав свої значення:
#
# VITE_LIVEKIT_URL=wss://YOUR_SUBDOMAIN.livekit.cloud
# LIVEKIT_API_KEY=APIxxxxxxxx
# LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Продакшен / Preview (Vercel): обов’язково VITE_LIVEKIT_URL + LIVEKIT_API_KEY + LIVEKIT_API_SECRET.
# У Settings → Environment Variables для гілок preview додай ті самі ключі, що й для Production
# (інакше preview-деплой збере порожній VITE_LIVEKIT_URL і overlay покаже «не налаштовано»).
# Токен за замовчуванням: /api/livekit-token (api/livekit-token.js). Окремий бекенд — лише тоді:
# VITE_LIVEKIT_TOKEN_URL=https://your-domain.com/api/livekit-token
#
# Обмежити шар відео для підписників (економія CPU/трафіку; потрібен simulcast): high | medium | low
# За замовчуванням high — макс. шар. Для продакшену часто: OBS/запис — high, решта клієнтів — medium або low.
# Або в URL /overlay?lk_q=low|medium|high (перебиває env для сесії)
# VITE_LK_SUBSCRIBE_VIDEO_QUALITY=low
