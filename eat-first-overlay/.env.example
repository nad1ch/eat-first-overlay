# Скопіюй у .env і заповни (файл .env не комітиться)
# Має збігатися з літералом у firestore.rules (request.resource.data.key == "...")
VITE_ADMIN_KEY=change-me-strong-secret

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Vercel: Project → Settings → Environment Variables — додай ті самі VITE_* для Production (і Preview за потреби).
