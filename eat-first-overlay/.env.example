# Canonical: origin без слеша в кінці — у проді клієнт виставляє rel=canonical і og:url під повний path + query
# У репо вже є .env.production для https://eat-first-overlay.vercel.app
# VITE_PUBLIC_CANONICAL_ORIGIN=https://eat-first-overlay.vercel.app

# Plausible: домен сайту в акаунті Plausible (без https://)
# VITE_PLAUSIBLE_DOMAIN=eat-first-overlay.vercel.app

# Google Analytics 4 — лише якщо потрібно (Measurement ID G-…)
# VITE_GA_MEASUREMENT_ID=
